#!/usr/bin/env sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
APP_JS="$ROOT/build/js/packages/TrikeShed-libs-dreamer-dashboard/kotlin/TrikeShed-libs-dreamer-dashboard.js"

if ! command -v node >/dev/null 2>&1; then
  echo "Dreamer needs node on PATH." >&2
  exit 1
fi

case "${1:-}" in
  --no-build)
    shift
    ;;
  *)
    "$ROOT/gradlew" -p "$ROOT" -q :libs:dreamer-dashboard:compileDevelopmentExecutableKotlinJs --console=plain
    ;;
esac

if [ ! -f "$APP_JS" ]; then
  echo "Dreamer app is not built. Run: ./dreamer" >&2
  exit 1
fi

exec node "$APP_JS" "$@"
