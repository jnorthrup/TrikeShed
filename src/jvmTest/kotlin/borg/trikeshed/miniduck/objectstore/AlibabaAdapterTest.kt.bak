package borg.trikeshed.miniduck.objectstore

import borg.trikeshed.miniduck.AlibabaRowVec
import borg.trikeshed.miniduck.BlobRowVec
import borg.trikeshed.miniduck.ObjectStoreProvider
import borg.trikeshed.miniduck.runBlockingCommon
import borg.trikeshed.lib.*
import kotlin.test.Test
import kotlin.test.assertEquals
import kotlin.test.assertIs
import kotlin.test.assertNotNull
import kotlin.test.assertTrue
@Suppress("unused")
private fun <T> rb(block: suspend () -> T): T = runBlockingCommon(block)

class AlibabaAdapterTest {

    @Test
    fun `AlibabaAdapter implements ObjectStoreAdapter with ALIBABA provider`() {
        val adapter: ObjectStoreAdapter = AlibabaAdapter(AlibabaAdapter.Config(
            endpoint = "oss-us-west-1.aliyuncs.com",
            bucket = "test-bucket",
            ossClient = FakeAlibabaOssClient(),
        ))
        assertEquals(ObjectStoreProvider.ALIBABA, adapter.provider)
    }

    @Test
    fun `AlibabaAdapter list returns AlibabaRowVec with bucket and key fields`() {
        runBlocking {
            val adapter = AlibabaAdapter(AlibabaAdapter.Config(
                endpoint = "oss-us-west-1.aliyuncs.com",
                bucket = "test-bucket",
                ossClient = FakeAlibabaOssClient(
                    listResults = listOf(
                        listOf(
                            FakeAlibabaOssObject("prefix/file1.txt", 12L, "\"etag1\""),
                            FakeAlibabaOssObject("prefix/file2.txt", 34L, "\"etag2\""),
                        )
                    ),
                ),
            ))

            val result = adapter.list("test-bucket", "prefix/", 100)

            assertTrue(result.objects.isNotEmpty())
            val first = result.objects[0] as AlibabaRowVec
            assertIs<AlibabaRowVec>(first)
            assertEquals("test-bucket", first.bucket)
            assertTrue(first.key.startsWith("prefix/"))
            // list() returns shell objects — child is null until accessed via get()
            assertTrue(first.child == null || first.child!!.size == 0)
        }
    }

    @Test
    fun `AlibabaAdapter get returns AlibabaRowVec with BlobRowVec child`() {
        runBlocking {
            val adapter = AlibabaAdapter(AlibabaAdapter.Config(
                endpoint = "oss-us-west-1.aliyuncs.com",
                bucket = "test-bucket",
                ossClient = FakeAlibabaOssClient(
                    getResults = listOf(FakeAlibabaOssGetObject(byteArrayOf(0x11.toByte(), 0x22.toByte()), "image/jpeg"))
                ),
            ))

            val result = adapter.get("test-bucket", "images/photo.jpg")

            assertTrue(result != null)
            val typedResult = result as AlibabaRowVec
            assertIs<AlibabaRowVec>(typedResult)
            assertEquals(ObjectStoreProvider.ALIBABA, typedResult.provider)
            assertEquals("images/photo.jpg", typedResult.key)
            val blob = typedResult.child!![0] as BlobRowVec
            assertTrue(byteArrayOf(0x11.toByte(), 0x22.toByte()).contentEquals(blob.bytes))
        }
    }

    @Test
    fun `AlibabaAdapter put stores bytes and returns true`() {
        runBlocking {
            var putCalled = false
            var putArgs: Pair<String, ByteArray>? = null
            val adapter = AlibabaAdapter(AlibabaAdapter.Config(
                endpoint = "oss-us-west-1.aliyuncs.com",
                bucket = "test-bucket",
                ossClient = FakeAlibabaOssClient(
                    putHook = { key, bytes ->
                        putCalled = true
                        putArgs = Pair(key, bytes)
                    }
                ),
            ))
            val bytes = "hello oss".toByteArray()

            val ok = adapter.put("test-bucket", "hello.txt", bytes, mapOf("contentType" to "text/plain"))

            assertTrue(ok)
            assertTrue(putCalled)
            assertEquals("hello.txt", putArgs?.first)
            assertTrue(bytes.contentEquals(putArgs!!.second))
        }
    }

    @Test
    fun `AlibabaAdapter delete calls client delete and returns true`() {
        runBlocking {
            var deleteCalled = false
            var deleteArgs: String? = null
            val adapter = AlibabaAdapter(AlibabaAdapter.Config(
                endpoint = "oss-us-west-1.aliyuncs.com",
                bucket = "test-bucket",
                ossClient = FakeAlibabaOssClient(
                    deleteHook = { key ->
                        deleteCalled = true
                        deleteArgs = key
                    }
                ),
            ))

            val ok = adapter.delete("test-bucket", "prefix/file.txt")

            assertTrue(ok)
            assertTrue(deleteCalled)
            assertEquals("prefix/file.txt", deleteArgs)
        }
    }

    @Test
    fun `AlibabaAdapter list with empty result returns empty ObjectListResult`() {
        runBlocking {
            val adapter = AlibabaAdapter(AlibabaAdapter.Config(
                endpoint = "oss-us-west-1.aliyuncs.com",
                bucket = "test-bucket",
                ossClient = FakeAlibabaOssClient(listResults = listOf(emptyList())),
            ))

            val result = adapter.list("test-bucket", "nonexistent/", 100)

            assertTrue(result.objects.isEmpty())
        }
    }

    @Test
    fun `AlibabaAdapter get returns null for missing object`() {
        runBlocking {
            val adapter = AlibabaAdapter(AlibabaAdapter.Config(
                endpoint = "oss-us-west-1.aliyuncs.com",
                bucket = "test-bucket",
                ossClient = FakeAlibabaOssClient(getResults = listOf(null)),
            ))

            val result = adapter.get("test-bucket", "nonexistent.txt")

            assertTrue(result == null)
        }
    }
}

// --- Fake Alibaba OSS SDK stubs for testing ---

data class FakeAlibabaOssObject(
    val key: String,
    val size: Long,
    val etag: String?,
    val lastModified: String? = null,
    val metadata: Map<String, String> = emptyMap(),
)

data class FakeAlibabaOssGetObject(
    val bytes: ByteArray,
    val contentType: String?,
    val etag: String? = null,
    val metadata: Map<String, String> = emptyMap(),
) {
    override fun equals(other: Any?): Boolean {
        if (this === other) return true
        if (other !is FakeAlibabaOssGetObject) return false
        return bytes.contentEquals(other.bytes) && contentType == other.contentType
    }
    override fun hashCode(): Int = bytes.contentHashCode() + contentType.hashCode()
}

class FakeAlibabaOssClient(
    val listResults: List<List<FakeAlibabaOssObject>> = listOf(emptyList()),
    val getResults: List<FakeAlibabaOssGetObject?> = listOf(null),
    val putHook: ((key: String, bytes: ByteArray) -> Unit)? = null,
    val deleteHook: ((key: String) -> Unit)? = null,
) : AlibabaOssClient {
   var listIdx = 0
   var getIdx = 0

    override fun listObjects(prefix: String): List<AlibabaOssObjectMetadata> {
        return if (listIdx < listResults.size) {
            listResults[listIdx++].filter { it.key.startsWith(prefix) }
                .map { AlibabaOssObjectMetadata(it.key, it.size, it.etag, it.lastModified, it.metadata) }
        } else emptyList()
    }

    override fun getObject(key: String): AlibabaOssObjectContent? {
        return if (getIdx < getResults.size) {
            val r = getResults[getIdx++]
            r?.let { AlibabaOssObjectContent(it.bytes, it.contentType, it.etag, it.metadata) }
        } else null
    }

    override fun putObject(key: String, bytes: ByteArray) {
        putHook?.invoke(key, bytes)
    }

    override fun deleteObject(key: String) {
        deleteHook?.invoke(key)
    }
}
