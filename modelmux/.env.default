# ModelMux Default Configuration
# This file provides sensible defaults - override with .env or .env.local
# Precedence: env var > .env.local > .env > .env.default > .env.example

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
MODELMUX_PORT=8888
MODELMUX_BIND_ADDRESS=0.0.0.0
MODELMUX_REQUEST_TIMEOUT_SECS=120
MODELMUX_MAX_RETRIES=2
MODELMUX_ENABLE_STREAMING=true
MODELMUX_ENABLE_CACHING=true

# =============================================================================
# MODEL DEFAULTS
# =============================================================================
MODELMUX_MAX_CONTEXT_WINDOW=128000

# =============================================================================
# PROVIDER BASE URLS (override if using custom endpoints)
# =============================================================================
KILO_BASE_URL=https://api.kilo.ai/api/gateway
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
ZENMUX_BASE_URL=https://zenmux.ai/api/v1
OPENCODE_BASE_URL=https://api.opencode.ai
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
XAI_BASE_URL=https://api.x.ai/v1
PERPLEXITY_BASE_URL=https://api.perplexity.ai