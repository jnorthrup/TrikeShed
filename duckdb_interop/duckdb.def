# TrikeShed DuckDB POSIX Bridge - C API Definition
#
# This wrapper includes the actual DuckDB header from the system

headers = /opt/homebrew/Cellar/duckdb/1.4.4/include/duckdb.h
headerFilter = /opt/homebrew/Cellar/duckdb/1.4.4/include/duckdb.h

# Include paths
compilerOpts.macos = -I/opt/homebrew/Cellar/duckdb/1.4.4/include
compilerOpts.macos_arm64 = -I/opt/homebrew/Cellar/duckdb/1.4.4/include

# Linker options
linkerOpts.macos = -L/opt/homebrew/Cellar/duckdb/1.4.4/lib -lduckdb
linkerOpts.macos_arm64 = -L/opt/homebrew/Cellar/duckdb/1.4.4/lib -lduckdb

# Type aliases
type aliases =
    idx_t = ULong

# Export all DuckDB functions and enums
exportForwardDeclarations = *
