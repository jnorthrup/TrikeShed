#!/usr/bin/env bash
# bin/trikeshed-jules - TrikeShed Jules REST API CLI v2 with predicates
#
# PREDICATES ENFORCED BEFORE TASK CREATION:
# 1. Clean worktree (no uncommitted changes)
# 2. HEAD identical to upstream (no unpushed commits)
# 3. Branch is master (or configured branch)
# 4. No existing "Awaiting User Feedback" sessions for this project
# 5. No more than N concurrent running sessions (quota check)
# 6. Prompt contains required keywords (JDK, TDD, PR, packages)
# 7. Prompt does NOT contain forbidden keywords (libs/, legacy paths)
#
# If any predicate fails, the task is rejected with explanation.

set -euo pipefail
shopt -s lastpipe

# =============================================================================
# CONFIG
# =============================================================================
JULES_API_BASE="https://jules.googleapis.com/v1alpha"
JULES_API_KEY="${JULES_API_KEY:-}"
JULES_OAUTH_TOKEN="${JULES_OAUTH_TOKEN:-}"
CACHE_DIR="${HOME}/.cache/jules-cli"

# Predicate configuration
MAX_CONCURRENT=10
REQUIRED_KEYWORDS=("TDD" "PR" "Deliver")
FORBIDDEN_PATTERNS=("libs/" "/libs" "lib/" "/lib" ".zenith/" "~/.zenith")
ALLOWED_BRANCH="${TRIKESHED_JULES_BRANCH:-master}"

# =============================================================================
# UTILITIES
# =============================================================================
log() { echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" >&2; }
die() { echo "ERROR: $*" >&2; exit 1; }

read_stdin_if_missing() {
    if [[ -n "${1:-}" ]]; then
        REPLY="$1"
    else
        REPLY="$(cat 2>/dev/null || true)"
    fi
    [[ -n "${REPLY}" ]]
}

# =============================================================================
# PREDICATE CHECKS
# =============================================================================

# Predicate 1: Clean worktree
check_clean_worktree() {
    local root="$1"
    if [[ -n "$(git -C "${root}" status --porcelain=v1 --untracked-files=all)" ]]; then
        git -C "${root}" status --short >&2
        die "PREDICATE FAILED: Dirty worktree. Commit or stash changes first."
    fi
    log "PREDICATE PASSED: Clean worktree"
}

# Predicate 2: HEAD identical to upstream
check_upstream_synced() {
    local root="$1"
    local branch upstream remote head_sha upstream_sha counts
    
    branch=$(git -C "${root}" branch --show-current)
    [[ -n "${branch}" ]] || die "PREDICATE FAILED: Detached HEAD"
    
    upstream=$(git -C "${root}" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null) \
        || die "PREDICATE FAILED: Branch '${branch}' has no upstream. Push first."
    
    remote=$(git -C "${root}" config --get "branch.${branch}.remote")
    [[ -n "${remote}" && "${remote}" != "." ]] \
        || die "PREDICATE FAILED: Branch '${branch}' does not track a remote."
    
    git -C "${root}" fetch --quiet "${remote}" \
        || die "PREDICATE FAILED: Could not fetch '${remote}'"
    
    head_sha=$(git -C "${root}" rev-parse HEAD)
    upstream_sha=$(git -C "${root}" rev-parse '@{upstream}')
    
    if [[ "${head_sha}" != "${upstream_sha}" ]]; then
        counts=$(git -C "${root}" rev-list --left-right --count 'HEAD...@{upstream}')
        die "PREDICATE FAILED: HEAD not identical to upstream (ahead/behind: ${counts}). Push or reconcile first."
    fi
    log "PREDICATE PASSED: HEAD identical to upstream"
}

# Predicate 3: Correct branch
check_correct_branch() {
    local root="$1"
    local branch
    branch=$(git -C "${root}" branch --show-current)
    if [[ "${branch}" != "${ALLOWED_BRANCH}" ]]; then
        die "PREDICATE FAILED: On branch '${branch}', but must be '${ALLOWED_BRANCH}'. Checkout correct branch first."
    fi
    log "PREDICATE PASSED: Correct branch (${branch})"
}

# Predicate 4: No Awaiting User Feedback sessions
check_no_awaiting_sessions() {
    local current
    current=$(api_request GET "/sessions?pageSize=100" 2>/dev/null | \
        jq -r --arg src "sources/github/jnorthrup/TrikeShed" \
        '[.sessions[]? | select(.state == "AWAITING_USER_FEEDBACK" and .sourceContext.source == $src)] | length' 2>/dev/null || echo "0")
    
    if [[ "${current}" -gt 0 ]]; then
        die "PREDICATE FAILED: ${current} sessions already Awaiting User Feedback. Nudge or resolve them first."
    fi
    log "PREDICATE PASSED: No awaiting sessions"
}

# Predicate 5: Concurrent quota check
check_concurrent_quota() {
    local active
    active=$(api_request GET "/sessions?pageSize=100" 2>/dev/null | \
        jq -r '[.sessions[]? | select(.state == "IN_PROGRESS" or .state == "PLANNING" or .state == "QUEUED")] | length' 2>/dev/null || echo "0")
    
    if [[ "${active}" -ge "${MAX_CONCURRENT}" ]]; then
        die "PREDICATE FAILED: ${active} active sessions (max ${MAX_CONCURRENT}). Wait for completion first."
    fi
    log "PREDICATE PASSED: Concurrent quota OK (${active}/${MAX_CONCURRENT})"
}

# Predicate 6: Required keywords in prompt
check_required_keywords() {
    local prompt="$1"
    local missing=()
    for kw in "${REQUIRED_KEYWORDS[@]}"; do
        if ! echo "${prompt}" | grep -qi "${kw}"; then
            missing+=("${kw}")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        die "PREDICATE FAILED: Prompt missing required keywords: ${missing[*]}"
    fi
    log "PREDICATE PASSED: Required keywords present"
}

# Predicate 7: No forbidden patterns
check_no_forbidden_patterns() {
    local prompt="$1"
    local found=()
    for pat in "${FORBIDDEN_PATTERNS[@]}"; do
        if echo "${prompt}" | grep -q "${pat}"; then
            found+=("${pat}")
        fi
    done
    if [[ ${#found[@]} -gt 0 ]]; then
        die "PREDICATE FAILED: Prompt contains forbidden patterns: ${found[*]}"
    fi
    log "PREDICATE PASSED: No forbidden patterns"
}

# Run all predicates
run_predicates() {
    local prompt="$1"
    local root
    
    root=$(git rev-parse --show-toplevel 2>/dev/null) \
        || die "Must run from inside a git worktree"
    
    log "Running predicates..."
    check_clean_worktree "${root}"
    check_upstream_synced "${root}"
    check_correct_branch "${root}"
    
    # These require API access
    if [[ -n "${JULES_API_KEY}" || -n "${JULES_OAUTH_TOKEN}" ]]; then
        check_no_awaiting_sessions
        check_concurrent_quota
    fi
    
    check_required_keywords "${prompt}"
    check_no_forbidden_patterns "${prompt}"
    
    log "ALL PREDICATES PASSED"
}

# =============================================================================
# API HELPERS
# =============================================================================
api_request() {
    local method="$1" path="$2" body="${3:-}"
    
    if [[ -z "${JULES_API_KEY}" && -z "${JULES_OAUTH_TOKEN}" ]]; then
        die "Set JULES_API_KEY or JULES_OAUTH_TOKEN"
    fi
    
    local url="${JULES_API_BASE}${path}"
    local -a auth_headers=()
    if [[ -n "${JULES_API_KEY}" ]]; then
        auth_headers=(-H "x-goog-api-key: ${JULES_API_KEY}")
    else
        auth_headers=(-H "Authorization: Bearer ${JULES_OAUTH_TOKEN}")
    fi
    
    if [[ -n "${body}" ]]; then
        curl -sS -X "${method}" "${url}" \
            "${auth_headers[@]}" \
            -H "Content-Type: application/json" \
            -d "${body}"
    else
        curl -sS -X "${method}" "${url}" "${auth_headers[@]}" -H "Content-Type: application/json"
    fi
}

api_call() {
    local method="$1" path="$2" body="${3:-}"
    local out
    out=$(api_request "${method}" "${path}" "${body}")
    
    if echo "${out}" | jq -e '.error' >/dev/null 2>&1; then
        echo "${out}" | jq .
        local msg; msg=$(echo "${out}" | jq -r '.error.message // "unknown error"')
        die "Jules API error: ${msg}"
    fi
    echo "${out}" | jq .
}

resolve_source_name() {
    local owner_repo="${TRIKESHED_JULES_SOURCE:-github/jnorthrup/TrikeShed}"
    local full="sources/${owner_repo}"
    if [[ -n "${JULES_API_KEY}" ]]; then
        local found
        found=$(api_request GET "/sources?pageSize=100" \
            | jq -r --arg n "${full}" '.sources[]? | select(.name == $n) | .name' 2>/dev/null \
            | head -1 || true)
        if [[ -n "${found}" && "${found}" != "null" ]]; then
            echo "${found}"
            return
        fi
    fi
    echo "${full}"
}

# =============================================================================
# COMMANDS
# =============================================================================
cmd_sessions() {
    api_call GET "/sessions?pageSize=100"
}

cmd_session() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_call GET "/${name}"
}

cmd_create() {
    local prompt="" title=""
    
    [[ -n "${1:-}" ]] && prompt="$1" || true
    [[ -n "${2:-}" ]] && title="$2" || true
    
    if ! read_stdin_if_missing "${prompt}"; then
        die "Prompt required (arg or stdin)"
    fi
    prompt="${REPLY}"
    
    # RUN ALL PREDICATES BEFORE CREATING
    run_predicates "${prompt}"
    
    local source starting_branch
    if [[ "${TRIKESHED_JULES_SKIP_BIND:-0}" == "1" ]]; then
        source="sources/github-jnorthrup-TrikeShed"
    else
        source=$(resolve_source_name)
    fi
    starting_branch="${TRIKESHED_JULES_BRANCH:-master}"
    
    local title_field=""
    if [[ -n "${title}" && "${TRIKESHED_JULES_NO_TITLE:-0}" != "1" ]]; then
        title_field=$(jq -n --arg t "${title}" '{title: $t}')
    else
        title_field='{}'
    fi
    
    local body
    body=$(jq -n \
        --arg prompt        "${prompt}" \
        --argjson require_approval false \
        --arg source        "${source}" \
        --arg startingBranch "${starting_branch}" \
        --argjson title_field "${title_field}" \
        '{
            prompt: $prompt
        } + $title_field + {
            requirePlanApproval: $require_approval,
            sourceContext: {
                source: $source,
                githubRepoContext: { startingBranch: $startingBranch }
            }
        }')
    
    api_call POST "/sessions" "${body}"
}

cmd_send() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"; shift
    local message="${1:-}"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    
    if ! read_stdin_if_missing "${message}"; then
        die "Message required (arg or stdin)"
    fi
    message="${REPLY}"
    
    local body
    body=$(jq -n --arg p "${message}" '{prompt: $p}')
    api_call POST "/${name}:sendMessage" "${body}"
}

cmd_approve() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_call POST "/${name}:approvePlan" "{}"
}

cmd_responses() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_call GET "/${name}/activities?pageSize=100"
}

cmd_activities_classify() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_request GET "/${name}/activities?pageSize=100" \
        | jq '[.activities[]? | {
              id, originator, description, createTime,
              kind: (
                if   .planGenerated    then "planGenerated"
                elif .planApproved     then "planApproved"
                elif .agentMessaged    then "agentMessage"
                elif .userMessaged     then "userMessage"
                elif .progressUpdated  then "progress"
                elif .sessionCompleted then "completed"
                elif .sessionFailed    then "failed"
                else "unknown" end
              ),
              message: (.agentMessaged.agentMessage // .userMessaged.userMessage // null),
              steps:   (.planGenerated.plan.steps // null),
              planId:  (.planApproved.planId // null),
              reason:  (.sessionFailed.reason // null),
              artifacts: (.artifacts // null)
            }]'
}

cmd_sources() {
    api_call GET "/sources?pageSize=100"
}

cmd_source_get() {
    [[ -n "${1:-}" ]] || die "Source id required"
    api_call GET "/sources/$1"
}

cmd_delete() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_call DELETE "/${name}"
}

cmd_pull() {
    [[ -n "${1:-}" ]] || die "Session id required"
    local sid="$1"
    [[ "${sid}" == sessions/* ]] && sid="${sid#sessions/}"
    if command -v jules >/dev/null 2>&1; then
        log "Pulling session ${sid} via jules CLI..."
        jules remote pull --session "${sid}" --apply
    else
        die "jules binary not found in PATH"
    fi
}

cmd_check() {
    # New command: Run predicates without creating a task
    log "Running predicates for current state..."
    run_predicates "dummy prompt for keyword check"
    log "All predicates pass!"
}

cmd_status() {
    # New command: Show current session status summary
    log "Session Status Summary"
    echo "======================"
    
    local sessions_json
    sessions_json=$(api_request GET "/sessions?pageSize=100" 2>/dev/null)
    
    local total active planning queued awaiting completed failed
    total=$(echo "${sessions_json}" | jq -r '[.sessions[]?] | length')
    active=$(echo "${sessions_json}" | jq -r '[.sessions[]? | select(.state == "IN_PROGRESS")] | length')
    planning=$(echo "${sessions_json}" | jq -r '[.sessions[]? | select(.state == "PLANNING")] | length')
    queued=$(echo "${sessions_json}" | jq -r '[.sessions[]? | select(.state == "QUEUED")] | length')
    awaiting=$(echo "${sessions_json}" | jq -r '[.sessions[]? | select(.state == "AWAITING_USER_FEEDBACK")] | length')
    completed=$(echo "${sessions_json}" | jq -r '[.sessions[]? | select(.state == "COMPLETED")] | length')
    failed=$(echo "${sessions_json}" | jq -r '[.sessions[]? | select(.state == "FAILED")] | length')
    
    echo "Total:     ${total}"
    echo "In Progress: ${active}"
    echo "Planning:   ${planning}"
    echo "Queued:    ${queued}"
    echo "Awaiting:  ${awaiting}"
    echo "Completed: ${completed}"
    echo "Failed:    ${failed}"
    echo ""
    echo "Predicate limits: max ${MAX_CONCURRENT} concurrent"
}

cmd_nudge() {
    # Nudge all awaiting sessions
    local sessions_json
    sessions_json=$(api_request GET "/sessions?pageSize=100" 2>/dev/null)
    
    local awaiting_sessions
    awaiting_sessions=$(echo "${sessions_json}" | jq -r '[.sessions[]? | select(.state == "AWAITING_USER_FEEDBACK")]')
    local count
    count=$(echo "${awaiting_sessions}" | jq 'length')
    
    if [[ "${count}" -eq 0 ]]; then
        log "No sessions awaiting user feedback"
        return
    fi
    
    log "Nudging ${count} sessions..."
    echo "${awaiting_sessions}" | jq -r '.[] | .id' | while read -r sid; do
        log "Nudging ${sid}..."
        cmd_send "${sid}" "Please proceed with implementation. Deliver a PR with non-empty diff and passing tests."
    done
    log "Done nudging"
}

cmd_merge_completed() {
    # Pull and merge all completed sessions with artifacts
    local sessions_json
    sessions_json=$(api_request GET "/sessions?pageSize=100" 2>/dev/null)
    
    local completed_sessions
    completed_sessions=$(echo "${sessions_json}" | jq -r '[.sessions[]? | select(.state == "COMPLETED")]')
    local count
    count=$(echo "${completed_sessions}" | jq 'length')
    
    if [[ "${count}" -eq 0 ]]; then
        log "No completed sessions"
        return
    fi
    
    log "Found ${count} completed sessions, checking for pullable patches..."
    
    echo "${completed_sessions}" | jq -r '.[] | .id' | while read -r sid; do
        local patch_len
        patch_len=$(api_request GET "/sessions/${sid}/activities?pageSize=100" 2>/dev/null | \
            jq -r '[.activities[]? | select(.artifacts != null) | .artifacts[]? | .changeSet.gitPatch.unidiffPatch] | map(length) | add // 0')
        
        if [[ "${patch_len}" -gt 0 ]]; then
            log "Found patch for ${sid} (${patch_len} bytes), pulling..."
            if command -v jules >/dev/null 2>&1; then
                jules remote pull --session "${sid}" --apply 2>&1 || true
            fi
        else
            log "No patch for ${sid}, skipping"
        fi
    done
    log "Done checking completed sessions"
}

# =============================================================================
# MAIN
# =============================================================================
CMD="${1:-}"
shift || true

case "${CMD}" in
    sessions|list) cmd_sessions "$@" ;;
    session|get)   cmd_session "$@" ;;
    create)       cmd_create "$@" ;;
    send|chat)    cmd_send "$@" ;;
    approve)      cmd_approve "$@" ;;
    responses|activities) cmd_responses "$@" ;;
    activities-classify) cmd_activities_classify "$@" ;;
    sources)      cmd_sources "$@" ;;
    source)       cmd_source_get "$@" ;;
    delete)      cmd_delete "$@" ;;
    pull)        cmd_pull "$@" ;;
    check)       cmd_check "$@" ;;
    status)      cmd_status "$@" ;;
    nudge)       cmd_nudge "$@" ;;
    merge-completed) cmd_merge_completed "$@" ;;
    help|--help|-h)
        cat <<'EOF'
trikeshed-jules v2 - TrikeShed Jules CLI with predicates

Commands:
  sessions, list               List all sessions
  session <id>                 Get session details
  create "prompt" [title]      Create new session (PREDICATES REQUIRED)
  send <id> "message"         Send message to awaiting session
  approve <id>                Approve pending plan
  responses <id>              Get session activities
  activities-classify <id>    Get classified activities
  sources                     List sources
  delete <id>                 Delete session
  pull <id>                   Pull and apply patch
  check                       Run predicates without creating task
  status                      Show session status summary
  nudge                       Nudge all awaiting sessions
  merge-completed             Pull all completed sessions with patches

Predicates (enforced on create):
  - Clean worktree (no uncommitted changes)
  - HEAD identical to upstream
  - On correct branch (master)
  - No existing "Awaiting User Feedback" sessions
  - Concurrent sessions below quota (${MAX_CONCURRENT})
  - Prompt contains required keywords: ${REQUIRED_KEYWORDS[*]}
  - Prompt has no forbidden patterns: ${FORBIDDEN_PATTERNS[*]}

Environment:
  JULES_API_KEY              REST API key (preferred)
  JULES_OAUTH_TOKEN          OAuth Bearer token
  TRIKESHED_JULES_BRANCH     Branch to use (default: master)
  TRIKESHED_JULES_SKIP_BIND  Skip source binding
  TRIKESHED_JULES_NO_TITLE   Let Jules pick title
EOF
        ;;
    *) die "Unknown command: ${CMD}. Run 'help' for usage." ;;
esac
