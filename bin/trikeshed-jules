#!/usr/bin/env bash
# bin/trikeshed-jules - TrikeShed Jules REST API CLI (v1alpha)
#
# ----------------------------------------------------------------------------
# Jules REST API spec — transcribed from
#   https://developers.google.com/jules/api/reference/rest
#   https://jules.google/docs/api/reference/{sessions,activities,sources,types}
# This header is the only authoritative description of the API in this
# repository. If a behavior in this file disagrees with this spec, this
# spec wins. If a behavior here disagrees with intent, fix the source —
# do not edit the spec.
#
# AUTH
#   Base URL : https://jules.googleapis.com/v1alpha
#   Header   : x-goog-api-key: ***          (NOT Bearer OAuth)
#              Content-Type: application/json          (for bodies)
#   GETs     : 200 OK with JSON body
#   POSTs    : 200 OK with empty / resource body
#   Errors   : 4xx with JSON `{ "error": { "code", "message", "status" } }`
#   Note     : 401 API_KEY_SERVICE_BLOCKED means OAuth was sent to the REST
#              endpoint. The official `jules` CLI uses Google OAuth device
#              flow (jules-cli keychain entry) — that is a DIFFERENT
#              credential than $JULES_API_KEY.
#
# RESOURCE NAMES
#   Session  = sessions/{session}                        e.g. sessions/1234567
#   Source   = sources/{source}                          e.g. sources/github-myorg-myrepo
#   Activity = sessions/{session}/activities/{activity}  e.g. sessions/1234/activities/act1
#   The bare numeric "id" returned in resources is also the session ID
#   you put into URL paths. The canonical resource name is the longer
#   "sessions/{numeric}" form.
#
#   SOURCE NAME GOTCHA: the docs use the form
#     "source": "sources/github-myorg-myrepo"
#   i.e. owner and repo joined with a dash, NOT slashed. The 20-Jul-2025
#   pre-existing sessions in this workspace carried the slash form
#   ("sources/github/jnorthrup/TrikeShed") — that's a binding bug.
#   This CLI now derives the name from GET /v1alpha/sources if the
#   default literal doesn't list.
#
# SESSIONS
#   POST   /v1alpha/sessions                              create
#   GET    /v1alpha/sessions                              list    ?pageSize&pageToken
#   GET    /v1alpha/sessions/{session}                   get
#   DELETE /v1alpha/sessions/{session}                   delete
#   POST   /v1alpha/sessions/{session}:sendMessage       send message
#   POST   /v1alpha/sessions/{session}:approvePlan       approve plan
#   Session body:
#     { name, id, prompt, title, sourceContext?, state, url,
#       requirePlanApproval?, automationMode?, outputs?,
#       createTime, updateTime }
#   SessionState (enum):
#     STATE_UNSPECIFIED, QUEUED, PLANNING,
#     AWAITING_PLAN_APPROVAL, AWAITING_USER_FEEDBACK,
#     IN_PROGRESS, PAUSED, FAILED, COMPLETED
#   SessionOutput (oneof): { pullRequest: { url, title, description } }
#   Session.sourceContext (oneof):
#     { source (required, "sources/{source}"),
#       githubRepoContext?: { startingBranch (required) } }
#   sendMessage body: { prompt: string (required) }  — answer an
#                     AWAITING_USER_FEEDBACK session
#   approvePlan body: {}  — only needed when requirePlanApproval=true
#                     was set at create time
#
# ACTIVITIES  (one event per activity; oneof on the `activity` union key)
#   GET    /v1alpha/sessions/{session}/activities                  list  ?pageSize&pageToken
#   GET    /v1alpha/sessions/{session}/activities/{activity}      get
#   Activity:
#     { name, id, originator ("user"|"agent"|"system"), description,
#       createTime, artifacts?: Artifact[],
#       exactly one of:
#         agentMessaged   : { agentMessage: string }
#         userMessaged    : { userMessage: string }
#         planGenerated   : { plan: { id, steps: PlanStep[], createTime } }
#         planApproved    : { planId: string }
#         progressUpdated : { title, description }
#         sessionCompleted: {}
#         sessionFailed   : { reason: string } }
#   PlanStep: { id, index (int32, 0-based), title, description }
#   Artifact (oneof):
#     { changeSet : ChangeSet{ source, gitPatch:
#                  GitPatch{ unidiffPatch, baseCommitId, suggestedCommitMessage }}}
#     { media     : { mimeType, data (base64) }}
#     { bashOutput: { command, output, exitCode }}
#   Disambiguation: classify by which top-level event key is set. The
#   artifacts[] rides alongside on output events.
#
# SOURCES
#   GET    /v1alpha/sources                       list  ?pageSize&pageToken&filter
#   GET    /v1alpha/sources/{source}              get
#   Source:
#     { name, id, githubRepo:
#         { owner, repo, isPrivate, defaultBranch: GitHubBranch{ displayName },
#           branches: GitHubBranch[] }}
#   filter uses AIP-160 strings:
#     name=sources/source1 OR name=sources/source2
#
# DELIVERY — COMPLETED is NOT a delivery.
#   state == COMPLETED  →  flag only
#   outputs[].pullRequest.url                       real PR
#   gitPatch.unidiffPatch.length > 0                real diff
#   COMPLETED with empty outputs and no PR          delivery failure
#
# NO stream / WebSocket: activities are pull-only (pageSize + pageToken).
# NO :rejectPlan, no :cancel session, no rate-limit header.
#
# ----------------------------------------------------------------------------
# Usage: trikeshed-jules <command> [args...]
# Commands: sessions, session, sources, source, create, send, approve,
#           delete, responses, activities-classify
# stdin:    create reads prompt from stdin if no first argument given.
#           send reads message from stdin if no second argument given.
#
# Env (REQUIRED — pick one)
#   JULES_API_KEY                                        REST API key (preferred)
#   JULES_OAUTH_TOKEN                                    Bearer from `jules` CLI
#
# Env (optional)
#   TRIKESHED_JULES_SOURCE                               override source name
#                                                        (default: github-jnorthrup-TrikeShed)
#   TRIKESHED_JULES_BRANCH                               starting branch (default: master)
#   TRIKESHED_JULES_SKIP_BIND=1                          don't call GET /sources first
#                                                        (offline; uses literal name)
#   TRIKESHED_JULES_NO_TITLE=1                           don't send title (Jules picks)
#
# Inputs
#   - Prompt / message: first positional arg, else read from stdin.
#
# Examples
#   trikeshed-jules sessions | jq '.sessions[] | {id, title, state}'
#   trikeshed-jules create "Refactor foo into one-line α" "T-FOO"
#   echo "Add tests for foo" | trikeshed-jules create - "T-FOO"
#   trikeshed-jules approve 1234567
#   trikeshed-jules send 1234567 "continue"
#   trikeshed-jules activities-classify 1234567 | jq '.[] | select(.kind=="planGenerated")'

set -euo pipefail
shopt -s lastpipe

# =============================================================================
# CONFIG
# =============================================================================
JULES_API_BASE="https://jules.googleapis.com/v1alpha"
JULES_API_KEY="${JULES_API_KEY:-}"
JULES_OAUTH_TOKEN="${JULES_OAUTH_TOKEN:-}"     # OAuth Bearer (jules CLI uses this)
CACHE_DIR="${HOME}/.cache/jules-cli"

# =============================================================================
# UTILITIES
# =============================================================================
log() { echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" >&2; }
die() { echo "ERROR: $*" >&2; exit 1; }

# Pull body from stdin if no arg given. Returns 0/1 not via echo so callers
# can capture without an extra newline.
read_stdin_if_missing() {
    if [[ -n "${1:-}" ]]; then
        REPLY="$1"
    else
        REPLY="$(cat 2>/dev/null || true)"
    fi
    [[ -n "${REPLY}" ]]
}

# New Jules work must start from exactly the revision visible upstream.
# This is deliberately not bypassable by an environment flag: a local-only
# commit or dirty worktree gives Jules a stale contract and creates merge debt.
require_clean_pushed_upstream() {
    command -v git >/dev/null 2>&1 || die "Required command 'git' not found"

    local root branch expected_branch upstream remote head_sha upstream_sha counts
    root=$(git rev-parse --show-toplevel 2>/dev/null) \
        || die "New Jules work must be created from inside a git worktree."
    branch=$(git -C "${root}" branch --show-current)
    [[ -n "${branch}" ]] || die "Detached HEAD: checkout the branch Jules will use, push it, then retry."

    expected_branch="${TRIKESHED_JULES_BRANCH:-master}"
    [[ "${branch}" == "${expected_branch}" ]] \
        || die "Checked out '${branch}', but Jules would start from '${expected_branch}'. Checkout '${expected_branch}', make it clean, push it, then retry."

    if [[ -n "$(git -C "${root}" status --porcelain=v1 --untracked-files=all)" ]]; then
        git -C "${root}" status --short >&2
        die "Dirty worktree: commit every intended file, preserve or remove unintended files, push, then retry."
    fi

    upstream=$(git -C "${root}" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null) \
        || die "Branch '${branch}' has no upstream. Push with: git push -u origin '${branch}'"
    remote=$(git -C "${root}" config --get "branch.${branch}.remote")
    [[ -n "${remote}" && "${remote}" != "." ]] \
        || die "Branch '${branch}' does not track a pushable remote. Configure and push an upstream first."

    log "Refreshing ${upstream} before Jules dispatch..."
    git -C "${root}" fetch --quiet "${remote}" \
        || die "Could not fetch '${remote}'; cannot prove the selected revision is upstream."

    head_sha=$(git -C "${root}" rev-parse HEAD)
    upstream_sha=$(git -C "${root}" rev-parse '@{upstream}')
    if [[ "${head_sha}" != "${upstream_sha}" ]]; then
        counts=$(git -C "${root}" rev-list --left-right --count 'HEAD...@{upstream}')
        die "HEAD is not identical to ${upstream} (ahead/behind: ${counts}). Reconcile and push before creating Jules work."
    fi

    log "Dispatch barrier passed: clean ${branch} at ${head_sha:0:12}, identical to ${upstream}."
}

# JSON helper. Single arg = raw body; pass --json to validate output.
api_request() {
    local method="$1" path="$2" body="${3:-}"

    if [[ -z "${JULES_API_KEY}" && -z "${JULES_OAUTH_TOKEN}" ]]; then
        die "Set JULES_API_KEY (REST API key) or JULES_OAUTH_TOKEN (CLI Bearer)."
    fi

    local url="${JULES_API_BASE}${path}"
    local -a auth_headers=()
    if [[ -n "${JULES_API_KEY}" ]]; then
        auth_headers=(-H "x-goog-api-key: ${JULES_API_KEY}")
    else
        auth_headers=(-H "Authorization: Bearer ${JULES_OAUTH_TOKEN}")
    fi

    if [[ -n "${body}" ]]; then
        curl -sS -X "${method}" "${url}" \
            "${auth_headers[@]}" \
            -H "Content-Type: application/json" \
            -d "${body}"
    else
        curl -sS -X "${method}" "${url}" "${auth_headers[@]}" -H "Content-Type: application/json"
    fi
}

# Pretty-print a Jules error and exit non-zero. Used by every command's
# response handler so the shell pipeline actually fails on 4xx — the
# previous wrapper silently dropped them.
api_call() {
    local method="$1" path="$2" body="${3:-}"
    local out http
    out=$(api_request "${method}" "${path}" "${body}")
    http=$(curl -sS -o /dev/null -w "%{http_code}" -X "${method}" "${JULES_API_BASE}${path}" \
        $([[ -n "${JULES_API_KEY}" ]] && printf -- "-H x-goog-api-key:*** " "${JULES_API_KEY}"; \
          [[ -n "${JULES_OAUTH_TOKEN}" && -z "${JULES_API_KEY}" ]] && printf -- "-H Authorization:*** %s " "${JULES_OAUTH_TOKEN}"; \
          [[ -n "${body}" ]] && printf -- "-H Content-Type:application/json -d %s " "$(printf '%s' "${body}" | jq -Rs .)") 2>/dev/null) || true

    # Plain JSON probe — if output looks like { error: ... } fail loudly.
    if echo "${out}" | jq -e '.error' >/dev/null 2>&1; then
        echo "${out}" | jq .
        local msg; msg=$(echo "${out}" | jq -r '.error.message // "unknown error"')
        die "Jules API error: ${msg}"
    fi
    echo "${out}" | jq .
}

# =============================================================================
# SOURCE NAME RESOLUTION  (the binding bug fix)
# =============================================================================
# Default literal used to be "sources/github/jnorthrup/TrikeShed" which is
# the SLASH form — never accepted by the API. The docs use the DASH form
# "sources/github-jnorthrup-TrikeShed". We pick the dash form as default
# and resolve via GET /sources if a match is available.
resolve_source_name() {
    # NOTE: the live API returns sources of the form
    #   sources/github/<owner>/<repo>     (slash form)
    # NOT sources/github-<owner>-<repo>  (dash form). The slash form
    # is the canonical value; we use it as the probe and fall back to
    # the literal listed source if the GET round-trip succeeds.
    local owner_repo="${TRIKESHED_JULES_SOURCE:-github/jnorthrup/TrikeShed}"
    local full="sources/${owner_repo}"
    if [[ -n "${JULES_API_KEY}" ]]; then
        local found
        found=$(api_request GET "/sources?pageSize=100" \
            | jq -r --arg n "${full}" '.sources[]? | select(.name == $n) | .name' 2>/dev/null \
            | head -1 || true)
        if [[ -n "${found}" && "${found}" != "null" ]]; then
            echo "${found}"
            return
        fi
    fi
    echo "${full}"
}

# =============================================================================
# COMMANDS
# =============================================================================
cmd_sessions() {
    api_call GET "/sessions?pageSize=100"
}

cmd_session() {
    [[ -n "${1:-}" ]] || die "Session name required (e.g. sessions/1234567 or 1234567)"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_call GET "/${name}"
}

cmd_create() {
    require_clean_pushed_upstream

    local prompt="" title="" require_approval="false"

    # Only argument is the prompt (or stdin). Title is optional env or Jules picks.
    # Usage: trikeshed-jules create "prompt" [title]
    #   or: echo "prompt" | trikeshed-jules create
    # Title is optional — if omitted or TRIKESHED_JULES_NO_TITLE=1, Jules generates one.
    [[ -n "${1:-}" ]] && prompt="$1" || true
    [[ -n "${2:-}" ]] && title="$2" || true

    if ! read_stdin_if_missing "${prompt}"; then
        die "Prompt required (arg or stdin)"
    fi
    prompt="${REPLY}"

    # Auto-binding: look up the canonical source name. Set
    # TRIKESHED_JULES_SKIP_BIND=1 to skip the GET (e.g. offline).
    local source starting_branch
    if [[ "${TRIKESHED_JULES_SKIP_BIND:-0}" == "1" ]]; then
        source="sources/github-jnorthrup-TrikeShed"
    else
        source=$(resolve_source_name)
    fi
    starting_branch="${TRIKESHED_JULES_BRANCH:-master}"

    local body
    # Build the body in two passes: always-present fields, then conditionally
    # add the title key. (jq does not allow raw `if` expressions as object
    # keys — only `,` patterns inside one object literal work, and only if
    # the condition returns a valid merge. Cleaner to build the conditional
    # object separately and merge.)
    local title_field=""
    if [[ -n "${title}" && "${TRIKESHED_JULES_NO_TITLE:-0}" != "1" ]]; then
        title_field=$(jq -n --arg t "${title}" '{title: $t}')
    else
        title_field='{}'
    fi
    body=$(jq -n \
        --arg prompt        "${prompt}" \
        --argjson require_approval "${require_approval}" \
        --arg source        "${source}" \
        --arg starting_branch "${starting_branch}" \
        --argjson title_field "${title_field}" \
        '{
            prompt: $prompt
        } + $title_field + {
            requirePlanApproval: $require_approval,
            sourceContext: {
                source: $source,
                githubRepoContext: { startingBranch: $starting_branch }
            }
        }')

    api_call POST "/sessions" "${body}"
}

cmd_send() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"; shift
    local message="${1:-}"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"

    if ! read_stdin_if_missing "${message}"; then
        die "Message required (arg or stdin)"
    fi
    message="${REPLY}"

    local body
    body=$(jq -n --arg p "${message}" '{prompt: $p}')
    api_call POST "/${name}:sendMessage" "${body}"
}

cmd_approve() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    # approvePlan body is the empty JSON object per spec.
    api_call POST "/${name}:approvePlan" "{}"
}

cmd_responses() {
    # Per spec: activities is a oneof, not a fixed planApproved/planGenerated
    # pair. We return the raw activities[] and let jq classify.
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_call GET "/${name}/activities?pageSize=100"
}

cmd_activities_classify() {
    # Like responses() but tagged for human consumption.
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_request GET "/${name}/activities?pageSize=100" \
        | jq '[.activities[]? | {
              id, originator, description, createTime,
              kind: (
                if   .planGenerated    then "planGenerated"
                elif .planApproved     then "planApproved"
                elif .agentMessaged    then "agentMessage"
                elif .userMessaged     then "userMessage"
                elif .progressUpdated  then "progress"
                elif .sessionCompleted then "completed"
                elif .sessionFailed    then "failed"
                else "unknown" end
              ),
              message: (.agentMessaged.agentMessage // .userMessaged.userMessage // null),
              steps:   (.planGenerated.plan.steps // null),
              planId:  (.planApproved.planId // null),
              reason:  (.sessionFailed.reason // null),
              artifacts: (.artifacts // null)
            }]'
}

cmd_sources() {
    api_call GET "/sources?pageSize=100"
}

cmd_source_get() {
    [[ -n "${1:-}" ]] || die "Source id required"
    api_call GET "/sources/$1"
}

cmd_delete() {
    [[ -n "${1:-}" ]] || die "Session name required"
    local name="$1"
    [[ "${name}" == sessions/* ]] || name="sessions/${name}"
    api_call DELETE "/${name}"
}

cmd_pull() {
    # Delegate to the official `jules` CLI (OAuth) for pull+apply; that
    # piece requires the CLI credential, not the API key. We don't try
    # to re-implement apply since `jules remote pull` is the supported
    # path for local file application.
    [[ -n "${1:-}" ]] || die "Session id required"
    local sid="$1"
    [[ "${sid}" == sessions/* ]] && sid="${sid#sessions/}"
    if command -v jules >/dev/null 2>&1; then
        log "Pulling session ${sid} via jules CLI (OAuth)..."
        jules remote pull --session "${sid}" --apply
    else
        die "jules binary not found in PATH. Install jules CLI to use 'pull'."
    fi
}

# Backwards-compat aliases
cmd_chat() { cmd_send "$@"; }
cmd_list() { cmd_sessions; }
cmd_get()  { cmd_session "$@"; }
cmd_activities() { cmd_responses "$@"; }

show_help() {
    cat <<'EOF'
Usage: trikeshed-jules <command> [args...]

Spec header in this file documents the full API surface and is authoritative
over this help text.

Sessions
  sessions, list                                       list all sessions
  session <id|name>                                    get one session
  delete <id|name>                                     delete session
  create "prompt" [title]                              create session
                                                       (auto-binds to TrikeShed
                                                        via GET /sources; requires
                                                        clean HEAD == git upstream)
  send|chat <id|name> ["message"]                      message AWAITING_USER_FEEDBACK
  approve <id|name>                                    approve pending plan
  pull <id>                                            pull + apply (delegates to
                                                       the OAuth-authed jules CLI)

Activities (per session)
  responses|activities <id|name>                       raw activities[]
  activities-classify <id|name>                        activities[] classified
                                                       by event-kind oneof

Sources
  sources                                              list sources
  source <id>                                          get one source

Env (REQUIRED — pick one)
  JULES_API_KEY                                        REST API key (preferred)
  JULES_OAUTH_TOKEN                                    Bearer from `jules` CLI

Env (optional)
  TRIKESHED_JULES_SOURCE                               override source name
                                                       (default: github-jnorthrup-TrikeShed)
  TRIKESHED_JULES_BRANCH                               starting branch (default: master)
  TRIKESHED_JULES_SKIP_BIND=1                          don't call GET /sources first
                                                       (offline; uses literal name)
  TRIKESHED_JULES_NO_TITLE=1                           don't send title (Jules picks)

Inputs
  - Prompt / message: first positional arg, else read from stdin.

Examples
  trikeshed-jules sessions | jq '.sessions[] | {id, title, state}'
  trikeshed-jules create "Refactor foo into one-line α" "T-FOO"
  echo "Add tests for foo" | trikeshed-jules create - "T-FOO"
  trikeshed-jules approve 1234567
  trikeshed-jules send 1234567 "continue"
  trikeshed-jules activities-classify 1234567 | jq '.[] | select(.kind=="planGenerated")'
EOF
}

show_version() {
    echo "trikeshed-jules 2.1.0 (spec-revision 2026-07-19; upstream-push barrier)"
}

# =============================================================================
# MAIN
# =============================================================================
command -v curl >/dev/null 2>&1 || die "Required command 'curl' not found"
command -v jq   >/dev/null 2>&1 || die "Required command 'jq' not found"

CMD="${1:-}"; shift || true

case "${CMD}" in
    --help|-h)              show_help ;;
    --version|-v)           show_version ;;

    sessions|list)          cmd_sessions "$@" ;;
    session|get)            cmd_session "$@" ;;
    delete)                 cmd_delete "$@" ;;
    create)                 cmd_create "$@" ;;
    send|chat)              cmd_send "$@" ;;
    approve)                cmd_approve "$@" ;;
    pull)                   cmd_pull "$@" ;;

    responses|activities)   cmd_responses "$@" ;;
    activities-classify)    cmd_activities_classify "$@" ;;

    sources)                cmd_sources ;;
    source)                 cmd_source_get "$@" ;;

    *)                      show_help; die "Unknown command: ${CMD}" ;;
esac