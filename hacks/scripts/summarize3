#!/bin/bash
set -e  # Exit immediately if a command exits with a non-zero status.

# Function to log messages
log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $1" >&2
}

# Function to clean up on successful completion
cleanup() {
    log "Cleaning up temporary files"
    cmake --build . --target clean_all -- VERBOSE=1
    cd - > /dev/null
    rm -rf "$WORKDIR"
}

# Trap function to handle script exit
on_exit() {
    exit_code=$?
    if [ $exit_code -eq 0 ]; then
        # Successful completion
        cleanup
    else
        # Failure occurred
        log "Script failed with exit code $exit_code"
        log "Preserving working directory for inspection: $WORKDIR"
    fi
}

# Set the trap to call on_exit on EXIT
trap 'on_exit' EXIT

# Check if a URL or file is provided
if [ $# -eq 0 ]; then
    echo "Usage: $0 <URL or file> [output_dir] [ollama_model]"
    exit 1
fi

# Set up variables
INPUT="$1"
OUTPUT_DIR="${2:-$PWD}"  # Use second argument as output dir, or current dir if not provided
OLLAMA_MODEL="${3:-llama2}"  # Use third argument as Ollama model, or llama2 if not provided

# Determine if INPUT is a URL or a file
if [[ "$INPUT" =~ ^https?:// ]] || [[ "$INPUT" =~ ^www\. ]]; then
    IS_URL=true
    log "Input is a URL"
else
    IS_URL=false
    log "Input is a local file"

    # Get the absolute path of the input file before changing directories
    export ABSOLUTE_PATH="$(pwd -P)/${INPUT[*]}"
    log "Absolute path: $ABSOLUTE_PATH"
    if [ ! -f "$ABSOLUTE_PATH" ]; then
        log "Error: File not found: $ABSOLUTE_PATH"
        exit 1
    fi
fi

# Now create and move to the temporary working directory
WORKDIR=$(mktemp -d)
if [ ! -d "$WORKDIR" ]; then
    log "Error: Failed to create temporary working directory"
    exit 1
fi

cd "$WORKDIR" || exit 1
log "Working directory: $WORKDIR"

# Generate a consistent MD5 hash for the input
MD5=$(printf '%s' "$INPUT" | md5sum | cut -d' ' -f1)
log "Generated MD5: $MD5"

# Generate a sanitized filename with MD5 hash and original extension
ORIGINAL_EXT="${INPUT##*.}"
FILENAME="${MD5}_$(basename "$INPUT" | sed 's/[^a-zA-Z0-9._-]/_/g')"
FILENAME="${FILENAME%.*}.${ORIGINAL_EXT}"
log "Sanitized filename: $FILENAME"

# Check for required tools
for tool in yt-dlp ffmpeg whisper-cpp sed awk ollama; do
    if ! command -v $tool &> /dev/null; then
        log "Error: $tool is required but not found in PATH"
        exit 1
    fi
done

# Generate CMakeLists.txt
cat << 'EOT' > CMakeLists.txt
cmake_minimum_required(VERSION 3.10)
project(SummarizeAudio)

# Set variables
set(YTDLP "yt-dlp")
set(FFMPEG "ffmpeg")
set(WHISPERCPP "whisper-cpp")
set(WHISPERMODELS "$ENV{HOME}/.local/share/whisper-cpp/models/")
set(AWK "awk")
set(OLLAMA_MODEL "$ENV{OLLAMA_MODEL}")
set(INPUT "$ENV{INPUT}")
set(ABSOLUTE_PATH "$ENV{ABSOLUTE_PATH}")
set(MD5 "$ENV{MD5}")
set(FILENAME "$ENV{FILENAME}")
set(WAV_FILE "${FILENAME}.wav")
set(VTT_FILE "${FILENAME}.vtt")
set(TXT_FILE "${FILENAME}.txt")
set(SUMMARY_FILE "${FILENAME}_summary.txt")
set(OGG_FILE "${FILENAME}.ogg")

# Add custom commands
if(IS_URL)
    add_custom_command(OUTPUT ${WAV_FILE}
        COMMAND ${YTDLP} -N 3 -x --audio-format wav --postprocessor-args "-ar 16k" --cookies-from-browser brave --output ${WAV_FILE} ${INPUT}
        COMMENT "Downloading audio from URL")
else()
    add_custom_command(OUTPUT ${WAV_FILE}

        COMMAND ${FFMPEG} -i "${ABSOLUTE_PATH}" -ar 16000 -ac 1 -c:a pcm_s16le "${WAV_FILE}"
        COMMENT "Converting local file to WAV")
endif()

add_custom_command(OUTPUT ${VTT_FILE} DEPENDS ${WAV_FILE}
    COMMAND ${WHISPERCPP} -m "${WHISPERMODELS}/ggml-small.en-tdrz.bin" -ovtt -tdrz "${WAV_FILE}"
    COMMENT "Generating VTT file")

add_custom_command(OUTPUT ${TXT_FILE} DEPENDS "${VTT_FILE}"
    COMMAND ${AWK} -f process_vtt.awk "${VTT_FILE}" > "${TXT_FILE}"
    COMMENT "Generating TXT file")

add_custom_command(OUTPUT ${SUMMARY_FILE} DEPENDS ${TXT_FILE}
    COMMAND ollama run ${OLLAMA_MODEL} "Summarize this transcript:" < "${TXT_FILE}" > "${SUMMARY_FILE}"
    COMMENT "Generating summary")

add_custom_command(OUTPUT ${OGG_FILE} DEPENDS ${WAV_FILE}
    COMMAND ${FFMPEG} -i ${WAV_FILE} -c:a libopus -ar 16k -vbr on ${OGG_FILE}
    COMMENT "Converting WAV to OGG")

# Add custom targets
add_custom_target(build_all DEPENDS ${VTT_FILE} ${TXT_FILE} ${SUMMARY_FILE} ${OGG_FILE})
add_custom_target(clean_all
    COMMAND ${CMAKE_COMMAND} -E remove ${WAV_FILE} ${VTT_FILE} ${TXT_FILE} ${OGG_FILE}
    COMMENT "Cleaning up generated files")

# Include the AWK script as a file
file(WRITE process_vtt.awk "
BEGIN { FS=\"\\n\"; RS=\"\"; }
{
    for (i=1; i<=NF; i++) {
        gsub(/<[^>]*>/, \"\", \$i);
        \$i = gensub(/^[ \\t]+|[ \\t]+\$/, \"\", \"g\", \$i);
    }
    match(\$0, /^([0-9]+:[0-9]{2}:[0-9]{2})\\.[0-9]{3} --> .*/, arr);
    start_time = arr[1];
    text = \"\";
    for (i=2; i<=NF; i++) {
        if (\$i !~ /^[0-9]+:[0-9]{2}:[0-9]{2}\\.[0-9]{3} --> .*/) {
            text = text \" \" \$i;
        }
    }
    text = gensub(/^[ \\t]+|[ \\t]+\$/, \"\", \"g\", text);
    if (prev_text != \"\" && index(text, prev_text) == 1) {
        prev_text = text;
        prev_time = start_time;
    } else {
        if (prev_text != \"\") {
            print prev_time \" \" prev_text;
        }
        prev_text = text;
        prev_time = start_time;
    }
}
END {
    if (prev_text != \"\") {
        print prev_time \" \" prev_text;
    }
}
")
EOT

# Run CMake
log "Starting CMake process"
cmake -DIS_URL=${IS_URL} -DINPUT="${INPUT}" -DABSOLUTE_PATH="${ABSOLUTE_PATH}" -DMD5="${MD5}" -DFILENAME="${FILENAME}" -DOLLAMA_MODEL="${OLLAMA_MODEL}" .
cmake --build . --target build_all -- VERBOSE=1

# Check if all files exist and have content
for file in "${FILENAME}.vtt" "${FILENAME}.txt" "${FILENAME}_summary.txt" "${FILENAME}.ogg"; do
    if [ ! -s "$file" ]; then
        log "Error: $file not created or is empty. Check the CMake output above for errors."
        exit 1
    fi
done

# Move output files to the specified output directory
mv "${FILENAME}.vtt" "${FILENAME}.txt" "${FILENAME}_summary.txt" "${FILENAME}.ogg" "$OUTPUT_DIR"

# Output results
echo "Summary:"
cat "$OUTPUT_DIR/${FILENAME}_summary.txt"
echo -e "\nProcessed files in $OUTPUT_DIR:"
ls -l "$OUTPUT_DIR/${FILENAME}"*

# The cleanup will happen in the trap function upon successful completion