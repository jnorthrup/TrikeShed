{
  "name": "Document Processing Pipeline",
  "description": "Generic workflow demonstrating file ingestion, LLM processing, code execution, agent delegation, and artifact creation",
  "steps": [
    {
      "id": "step1-ingest",
      "type": "LlmCall",
      "promptId": "summarize-document",
      "inputs": {
        "document": "{{input.content}}"
      },
      "model": "gpt-4o-mini",
      "parameters": { "temperature": "0.2" }
    },
    {
      "id": "step2-extract",
      "type": "CodeExecution",
      "language": "python",
      "code": "import json\nimport re\ntext = input.summary\n# Extract key entities\nentities = re.findall(r'[A-Z][a-z]+ [A-Z][a-z]+', text)\nkeywords = re.findall(r'\\b(?:AI|ML|API|database|server|client|model|data|cloud|security|performance)\\b', text, re.IGNORECASE)\nresult = json.dumps({\n    \"entities\": list(set(entities)),\n    \"keywords\": list(set(keywords)),\n    \"word_count\": len(text.split())\n})",
      "inputs": {
        "summary": "{{step1-ingest.output}}"
      },
      "timeoutMs": 5000
    },
    {
      "id": "step3-enhance",
      "type": "AgentInvocation",
      "agentType": "LCNC",
      "task": "Enrich extracted data with external knowledge and generate structured metadata",
      "context": {
        "summary": "{{step1-ingest.output}}",
        "extracted": "{{step2-extract.output}}"
      },
      "allowedTools": ["web_search", "read_file", "run_command"]
    },
    {
      "id": "step4-transform",
      "type": "FileTransform",
      "inputFileIds": [],
      "transform": "render-markdown-report",
      "outputPath": "reports/{{input.filename}}.md"
    },
    {
      "id": "step5-parallel",
      "type": "Parallel",
      "branches": [
        [
          {
            "id": "step5a-index",
            "type": "AgentInvocation",
            "agentType": "LCNC",
            "task": "Index document for search and retrieval",
            "context": {
              "document": "{{step1-ingest.output}}",
              "metadata": "{{step2-extract.output}}"
            },
            "allowedTools": ["write_file", "run_command"]
          }
        ],
        [
          {
            "id": "step5b-notify",
            "type": "AgentInvocation",
            "agentType": "LCNC",
            "task": "Send completion notification with key findings",
            "context": {
              "summary": "{{step1-ingest.output}}",
              "enhanced": "{{step3-enhance.output}}"
            },
            "allowedTools": ["run_command"]
          }
        ],
        [
          {
            "id": "step5c-archive",
            "type": "AgentInvocation",
            "agentType": "LCNC",
            "task": "Archive processed document with full lineage",
            "context": {
              "document": "{{step1-ingest.output}}",
              "report": "{{step4-transform.output}}"
            },
            "allowedTools": ["write_file", "run_command"]
          }
        ]
      ]
    },
    {
      "id": "step6-quality-gate",
      "type": "Conditional",
      "condition": "{{step2-extract.output.word_count}} > 100 and {{step3-enhance.output.confidence}} > 0.8",
      "thenBranch": [
        {
          "id": "step6a-publish",
          "type": "AgentInvocation",
          "agentType": "LCNC",
          "task": "Publish report to knowledge base",
          "context": {
            "report": "{{step4-transform.output}}",
            "metadata": "{{step2-extract.output}}"
          },
          "allowedTools": ["write_file", "run_command"]
        }
      ],
      "elseBranch": [
        {
          "id": "step6b-flag",
          "type": "LlmCall",
          "promptId": "quality-flag-prompt",
          "inputs": {
            "issues": "Document requires review: word_count={{step2-extract.output.word_count}}, confidence={{step3-enhance.output.confidence}}"
          },
          "model": "gpt-4o-mini"
        }
      ]
    },
    {
      "id": "step7-artifact",
      "type": "FileTransform",
      "inputFileIds": [],
      "transform": "create-artifact-bundle",
      "outputPath": "artifacts/{{input.filename}}-bundle.zip"
    }
  ]
}