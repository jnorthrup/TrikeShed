/**
 * External Graal process manager.
 */
class ExternalGraalProcess(
    private val transport: GraalTransport,
    private val config: ExternalGraalConfig
) {
    
    private var process: Process? = null
    private val eventQueue = ConcurrentLinkedQueue<SplatEvent>()
    private val responseQueue = ConcurrentLinkedQueue<ByteArray>()
    private var running = false
    
    data class ExternalGraalConfig(
        val graalExecutable: String = "graaljs",
        val scriptPath: String,
        val jvmOptions: List<String> = emptyList(),
        val timeout: Long = 30000,
        val workingDir: String? = null
    )
    
    companion object {
        fun create(config: ExternalGraalConfig): ExternalGraalProcess {
            val transport = when {
                config.graalExecutable.startsWith("unix:") -> GraalTransport.UnixSocket(config.graalExecutable.substringAfter("unix:"))
                config.graalExecutable.startsWith("tcp:") -> {
                    val parts = config.graalExecutable.substringAfter("tcp:").split(":")
                    GraalTransport.TcpSocket(parts[0], parts[1].toInt())
                }
                else -> GraalTransport.StdioTransport()
            }
            return ExternalGraalProcess(transport, config)
        }
    }
    
    private constructor(transport: GraalTransport, config: ExternalGraalConfig) {
        this.transport = transport
        this.config = config
    }
    
    fun start(): Boolean {
        try {
            val builder = ProcessBuilder()
                .command(buildCommand())
                .redirectErrorStream(true)
            
            config.workingDir?.let { processBuilder.directory(File(it)) }
            
            val process = processBuilder.start()
            this.process = process
            transport.connect()
            running = true
            
            // Start reader coroutine
            startReader()
            
            return true
        } catch (e: Exception) {
            return false
        }
    }
    
    private fun buildCommand(): List<String> {
        val cmd = mutableListOf<String>(config.graalExecutable)
        config.jvmOptions.forEach { cmd.add(it) }
        if (config.scriptPath.isNotEmpty()) {
            cmd.add(config.scriptPath)
        }
        return cmd
    }
    
    private fun startReader() {
        Thread {
            while (running) {
                val data = transport.receive()
                if (data != null) {
                    handleMessage(data)
                }
            }
        }.start()
    }
    
    private fun handleMessage(data: ByteArray) {
        // Parse and queue event
    }
    
    fun emitEvent(event: SplatEvent) {
        val data = PointcutEventSerializer().serialize(event)
        transport.send(data)
    }
    
    fun shutdown() {
        running = false
        transport.close()
        process?.destroy()
    }
    
    fun pollEvent(): SplatEvent? = eventQueue.poll()
}

/**
 * Parent-process VM mode for GraalPointcutHarness.
 * Uses composition instead of inheritance to avoid final method issues.
 */
class ParentProcessHarness(
    private val externalProcess: ExternalGraalProcess
) {
    
    private val harness = GraalPointcutHarness()
    
    fun eval(languageId: String, source: String): Any? {
        // Send source to external Graal process
        // This is a simplified implementation - real implementation would serialize the request
        return harness.eval(languageId, source)
    }
    
    fun close() {
        // Shutdown external process
    }
}