import java.io.*
import java.net.*
import java.nio.channels.*
import java.nio.ByteBuffer
import java.nio.channels.SocketChannel
import java.util.concurrent.*

/**
 * Transport protocol for parent-process VM communication.
 * Supports multiple transport mechanisms for Graal process communication.
 */
sealed class GraalTransport {
    abstract fun send(data: ByteArray)
    abstract fun receive(): ByteArray?
    abstract fun close()
    
    data class UnixSocket(val path: String) : GraalTransport() {
        private var socket: SocketChannel? = null
        
        override fun send(data: ByteArray) {
            socket?.write(ByteBuffer.wrap(data))
        }
        
        override fun receive(): ByteArray? {
            val buffer = ByteBuffer.allocate(8192)
            val read = socket?.read(buffer)
            if (read == null || read <= 0) return null
            buffer.flip()
            return buffer.array().copyOf(read)
        }
        
        override fun close() {
            socket?.close()
        }
        
        fun connect() {
            val socket = SocketChannel.open()
            socket.configureBlocking(true)
            socket.connect(InetSocketAddress("localhost", 0)) // Will need proper Unix socket implementation
            this.socket = socket
        }
    }
    
    data class TcpSocket(val host: String, val port: Int) : GraalTransport() {
        private var socket: Socket? = null
        private var out: OutputStream? = null
        private var `in`: InputStream? = null
        
        override fun send(data: ByteArray) {
            out?.write(IntArray(1){ data.size }.joinToString(""))
            out?.write(data)
            out?.flush()
        }
        
        override fun receive(): ByteArray? {
            val lengthBytes = ByteArray(4)
            val read = `in`?.read(lengthBytes)
            if (read != 4) return null
            val length = ByteBuffer.wrap(lengthBytes).int
            val data = ByteArray(length)
            var total = 0
            while (total < length) {
                val read = `in`?.read(data, total, length - total)
                if (read == null || read <= 0) return null
                total += read
            }
            return data
        }
        
        override fun close() {
            socket?.close()
        }
        
        fun connect() {
            socket = Socket(host, port)
            out = socket?.getOutputStream()
            `in` = socket?.getInputStream()
        }
    }
    
    data class StdioTransport : GraalTransport() {
        private val out = System.out.bufferedWriter()
        private val outLock = Any()
        
        override fun send(data: ByteArray) {
            synchronized(outLock) {
                val outStream = System.out.bufferedOutputStream()
                outStream.write(data.size.toByteArray())
                outStream.write(data)
                outStream.flush()
            }
        }
        
        override fun receive(): ByteArray? {
            val lengthBytes = ByteArray(4)
            val read = System.`in`.read(lengthBytes)
            if (read != 4) return null
            val length = ByteBuffer.wrap(lengthBytes).int
            val data = ByteArray(length)
            var total = 0
            while (total < length) {
                val read = System.`in`.read(data, total, length - total)
                if (read <= 0) return null
                total += read
            }
            return data
        }
        
        override fun close() {}
    }
}

