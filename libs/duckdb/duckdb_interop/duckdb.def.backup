headers.linux = \
    duckdb_wrapper.h

headers.macos = \
    duckdb_wrapper.h

# Include the directory containing the wrapper
compilerOpts.linux = -I/opt/homebrew/Cellar/duckdb/1.4.4/include -I/Users/jim/work/TrikeShed/duckdb_interop
compilerOpts.macos = -I/opt/homebrew/Cellar/duckdb/1.4.4/include -I/Users/jim/work/TrikeShed/duckdb_interop
compilerOpts.macosx64 = -I/opt/homebrew/Cellar/duckdb/1.4.4/include -I/Users/jim/work/TrikeShed/duckdb_interop

# Linker options
linkerOpts.linux = -L/opt/homebrew/lib -lduckdb
linkerOpts.macos = -L/opt/homebrew/lib -lduckdb
linkerOpts.macosx64 = -L/opt/homebrew/lib -lduckdb

# Export all declarations
exportForwardDeclarations = *

