{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.gwtproject.org/schemas/requestfactory.schema.json",
  "title": "GWT RequestFactory Contract",
  "type": "object",
  "required": ["factory", "contexts", "proxies"],
  "properties": {
    "factory": {
      "$ref": "#/$defs/RequestFactory"
    },
    "contexts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RequestContext"
      }
    },
    "proxies": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/EntityProxy" },
          { "$ref": "#/$defs/ValueProxy" }
        ]
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ValidationRule"
      }
    }
  },
  "$defs": {
    "RequestFactory": {
      "type": "object",
      "required": ["name", "servletPath", "requestPath"],
      "properties": {
        "name": { "type": "string" },
        "servletPath": { "type": "string", "const": "/gwtRequest" },
        "requestPath": { "type": "string", "const": "/gwtRequest" },
        "eventBusType": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RequestContext": {
      "type": "object",
      "required": ["name", "serviceType", "methods"],
      "properties": {
        "name": { "type": "string" },
        "serviceType": { "type": "string" },
        "serviceAnnotation": {
          "type": "string",
          "enum": ["Service", "ServiceName"]
        },
        "methods": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequestMethod"
          }
        }
      },
      "additionalProperties": false
    },
    "RequestMethod": {
      "type": "object",
      "required": ["name", "kind", "returnType", "parameters"],
      "properties": {
        "name": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["Request", "InstanceRequest"]
        },
        "returnType": { "type": "string" },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Parameter"
          }
        }
      },
      "additionalProperties": false
    },
    "Parameter": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "annotations": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "EntityProxy": {
      "type": "object",
      "required": ["name", "serverType", "properties"],
      "properties": {
        "name": { "type": "string" },
        "serverType": { "type": "string" },
        "idProperty": { "type": "string" },
        "versionProperty": { "type": "string" },
        "extraTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Property"
          }
        }
      },
      "additionalProperties": false
    },
    "ValueProxy": {
      "type": "object",
      "required": ["name", "serverType", "properties"],
      "properties": {
        "name": { "type": "string" },
        "serverType": { "type": "string" },
        "extraTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Property"
          }
        }
      },
      "additionalProperties": false
    },
    "Property": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "readOnly": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "ValidationRule": {
      "type": "object",
      "required": ["targetType", "constraint"],
      "properties": {
        "targetType": { "type": "string" },
        "constraint": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
