{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.gwtproject.org/schemas/gwt-rpc.schema.json",
  "title": "GWT-RPC Message",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/GwtRpcRequest" },
    { "$ref": "#/$defs/GwtRpcResponse" }
  ],
  "$defs": {
    "GwtRpcRequest": {
      "type": "object",
      "required": ["kind", "service", "method", "parameterTypes", "parameters"],
      "properties": {
        "kind": { "type": "string", "const": "request" },
        "service": { "type": "string" },
        "method": { "type": "string" },
        "parameterTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/Value" }
        },
        "serializationPolicy": { "type": "string" },
        "strongName": { "type": "string" },
        "async": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "GwtRpcResponse": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "const": "response" },
        "returnType": { "type": "string" },
        "value": { "$ref": "#/$defs/Value" },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/ConstraintViolation" }
        },
        "exceptionType": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ConstraintViolation": {
      "type": "object",
      "required": ["path", "message"],
      "properties": {
        "path": { "type": "string" },
        "message": { "type": "string" },
        "invalidValue": { "$ref": "#/$defs/Value" }
      },
      "additionalProperties": false
    },
    "Value": {
      "oneOf": [
        { "type": "null" },
        { "type": "string" },
        { "type": "boolean" },
        { "type": "integer" },
        { "type": "number" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/Value" }
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    }
  }
}
