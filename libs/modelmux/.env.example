# ModelMux Configuration
# Copy this file to .env and fill in your API keys
# Precedence: env var > .env.local > .env > .env.default > .env.example

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
MODELMUX_PORT=8888
MODELMUX_BIND_ADDRESS=0.0.0.0
MODELMUX_REQUEST_TIMEOUT_SECS=120
MODELMUX_MAX_RETRIES=2
MODELMUX_ENABLE_STREAMING=true
MODELMUX_ENABLE_CACHING=true

# =============================================================================
# MODEL DEFAULTS
# =============================================================================
# Default model to use when none specified
# Format: provider/model-name (e.g., kilo_code/minimax-minimax-m2.5:free)
# MODELMUX_DEFAULT_MODEL=kilo_code/minimax-minimax-m2.5:free

# Fallback model when primary is unavailable
# MODELMUX_FALLBACK_MODEL=moonshot/moonshot-v1-8k

# Maximum context window (tokens)
MODELMUX_MAX_CONTEXT_WINDOW=128000

# =============================================================================
# FREE TIER PROVIDERS (Recommended for development - DSEL prioritizes these)
# =============================================================================

# Kilo.ai Gateway - Access to 335+ models with free tier (1M tokens)
# Get API key: https://kilo.ai
KILO_API_KEY=your_kilo_api_key_here
KILO_BASE_URL=https://api.kilo.ai/api/gateway

# Alternative Kilo key names (any one works)
# KILOCODE_API_KEY=
# KILOAI_API_KEY=
# KILO_CODE_API_KEY=

# Moonshot (Kimi) - Chinese LLM provider with free tier (500K tokens)
# Get API key: https://platform.moonshot.cn
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Alternative Moonshot key names
# MOONSHOTAI_API_KEY=
# KIMI_API_KEY=

# DeepSeek - Code and chat models with free tier (500K tokens)
# Get API key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# NVIDIA - Nemotron and other models with free tier (500K tokens)
# Get API key: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ZenMux - Aggregated free tier (500K tokens)
# Get API key: https://zenmux.ai
ZENMUX_API_KEY=your_zenmux_api_key_here
ZENMUX_BASE_URL=https://zenmux.ai/api/v1

# OpenCode - Free tier (250K tokens)
# Get API key: https://opencode.ai
OPENCODE_API_KEY=your_opencode_api_key_here
OPENCODE_BASE_URL=https://api.opencode.ai

# Groq - Ultra-fast inference with free tier
# Get API key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# =============================================================================
# PAID PROVIDERS
# =============================================================================

# OpenAI - GPT-4, GPT-4o, GPT-4o-mini
# Get API key: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic - Claude Sonnet, Opus, Haiku
# Get API key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google - Gemini models
# Get API key: https://makersuite.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenRouter - Access to 300+ models (free and paid)
# Get API key: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cerebras - Ultra-fast inference
# Get API key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# xAI (Grok) - Grok models
# Get API key: https://console.x.ai
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1

# Perplexity - Sonar models with search
# Get API key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# Enable Ollama/OpenRouter free model passthrough
# MODELMUX_ENABLE_OLLAMA_OPENROUTER=false

# Enable OpenRouter fallback when primary providers exhausted
# MODELMUX_ENABLE_OPENROUTER_FALLBACK=false

# Include OpenRouter models in /v1/models listing
# MODELMUX_INCLUDE_OPENROUTER_MODELS=false

# Specific free model to use from OpenRouter
# OPENROUTER_FREE_MODEL=qwen/qwen3-4b:free

# HuggingFace API key for model metadata
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# =============================================================================
# SEARCH APIs (Optional - for RAG and web search)
# =============================================================================

# Brave Search API
# Get API key: https://brave.com/search/api
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Tavily Search API (AI-optimized search)
# Get API key: https://tavily.com
TAVILY_SEARCH_API_KEY=your_tavily_search_api_key_here

# =============================================================================
# LOGGING
# =============================================================================
RUST_LOG=info